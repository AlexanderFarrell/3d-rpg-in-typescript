{
	"name": "game",
	"private": true,
	"version": "0.1.0",
	"type": "module",
	"main": "out/main/main.js",
	"scripts": {
		"dev": "vite --host",
		"build": "tsc && vite build",
		"dev:desktop": "electron-vite dev",
		"build:desktop": "electron-vite build && electron-builder",
		"build:desktop:win": "electron-vite build && electron-builder --win",
		"build:desktop:wine": "electron-vite build && electron-builder --win portable",
		"build:desktop:mac": "electron-vite build && electron-builder --mac",
		"build:desktop:linux": "electron-vite build && electron-builder --linux"
	},
	"dependencies": {
		"electron-vite": "5.0.0",
		"engine": "file:../engine",
		"mitt": "^3.0.1",
		"vite": "7.3.2",
		"vue": "^3.5.33"
	},
	"devDependencies": {
		"@vitejs/plugin-vue": "^6.0.6",
		"electron": "41.3.0",
		"electron-builder": "26.8.1",
		"typescript": "^6.0.3"
	},
	"build": {
		"appId": "com.alexanderfarrell.rpgintypescript",
		"productName": "3D RPG in TypeScript",
		"files": [
			"out/**",
			"package.json"
		],
		"directories": {
			"output": "release"
		},
		"linux": {
			"target": [
				"AppImage"
			]
		},
		"win": {
			"target": [
				"nsis",
				"portable"
			]
		},
		"mac": {
			"target": [
				"dmg"
			]
		}
	}
}
